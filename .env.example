# Anvil local environment example
#
# Primary path:
# - copy config.example.yaml -> config.yaml
# - edit config.yaml to choose models
# - keep secrets here in .env

# Secrets referenced by config.example.yaml
OPENAI_BASE_URL=replace-me
OPENAI_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me
MINIMAX_API_KEY=replace-me
MIMO_API_KEY=replace-me
VOLCENGINE_API_KEY=replace-me
DEEPSEEK_API_KEY=replace-me
GEMINI_API_KEY=replace-me
MOONSHOT_API_KEY=replace-me
NOVITA_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me
MODELSCOPE_API_KEY=replace-me
GITHUB_TOKEN=replace-me
TAVILY_API_KEY=replace-me
EXA_API_KEY=replace-me
FIRECRAWL_API_KEY=replace-me
FIRECRAWL_API_URL=
JINA_API_KEY=
SEARXNG_BASE_URL=
BROWSER_CDP_URL=
GOOGLE_ACCESS_TOKEN=
GOOGLE_API_KEY=
GOOGLE_GMAIL_USER_ID=me
GOOGLE_GMAIL_FROM=
GOOGLE_CALENDAR_ID=primary
GOOGLE_GMAIL_BASE_URL=
GOOGLE_CALENDAR_BASE_URL=
VOICE_TOOLS_OPENAI_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
ELEVENLABS_API_KEY=
VLLM_API_KEY=replace-me
CUSTOM_OPENAI_BASE_URL=https://your-openai-compatible-gateway.example/v1
CUSTOM_OPENAI_API_KEY=replace-me

# Optional terminal backend profiles
ANVIL_TERMINAL_SSH_HOST=
ANVIL_TERMINAL_SSH_USER=
ANVIL_TERMINAL_SSH_WORKDIR=
ANVIL_TERMINAL_SINGULARITY_IMAGE=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
DAYTONA_API_KEY=
ANVIL_TERMINAL_DAYTONA_SANDBOX_ID=
ANVIL_TERMINAL_DAYTONA_WORKDIR=
VERCEL_TOKEN=
ANVIL_TERMINAL_VERCEL_SANDBOX_ID=
ANVIL_TERMINAL_VERCEL_WORKDIR=

# Frontend
# If ANVIL_BACKEND_PORT changes for Docker, update this URL to the same browser-visible port.
NEXT_PUBLIC_ANVIL_GATEWAY_URL=http://127.0.0.1:18000

# Local service ports
ANVIL_BACKEND_PORT=18000
ANVIL_FRONTEND_PORT=13200

# Optional host path bridge override for custom Docker launchers.
# The bundled scripts generate this automatically so Windows drives (C:, E:)
# or common macOS/Linux roots are mounted into the backend container.
# Format: alias|display_root|actual_root;alias2|display_root2|actual_root2
# ANVIL_PATH_BRIDGES=e_drive|E:|/mnt/host/e_drive

# Optional package mirrors for restricted networks or regional CI.
# Leave unset to use the default upstream registries.
# PIP_INDEX_URL=https://pypi.org/simple
# PIP_TRUSTED_HOST=
# NPM_REGISTRY=https://registry.npmjs.org

# Optional LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=replace-me
# LANGSMITH_PROJECT=anvil
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
#
# LangChain aliases are also accepted:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=replace-me
# LANGCHAIN_PROJECT=anvil
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
